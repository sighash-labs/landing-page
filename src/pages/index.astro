---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    title: 'UTXO Smart Contract Development',
    copy: 'Design and implementation support for covenant-driven applications, transaction builders, wallet flows, and production UTXO contracts.',
  },
  {
    title: 'Protocol Design & Consulting',
    copy: 'Hands-on guidance for teams building on Bitcoin, Bitcoin Cash, OPCAT layer, Liquid, Arkade, Fractal, and related Bitcoin-like systems.',
  },
  {
    title: 'Security Audits',
    copy: 'Manual reviews of UTXO smart contracts, transaction protocols, bridge assumptions, and application logic before launch.',
  },
];

const processSteps = [
  { title: 'Map the transaction model', detail: 'We start from the exact scripts, covenants, state transitions, signing flows, and chain constraints your product depends on.' },
  { title: 'Design or review the protocol', detail: 'We pressure-test the off-chain and on-chain pieces together, including failure modes, fee handling, replay risks, and upgrade paths.' },
  { title: 'Build with your team', detail: 'Engagements can include implementation, test harnesses, transaction construction, wallet integration, or focused engineering review.' },
  { title: 'Harden before release', detail: 'For audit work, you get concrete findings, exploit paths where relevant, and follow-up review of fixes.' },
];

const valueProps = [
  'Deep experience with UTXO smart contracting and Bitcoin-style transaction semantics.',
  'Practical support across consulting, implementation, and independent security review.',
  'Clear scopes and direct collaboration with the engineer doing the work.',
];

const showPartners = false;

const partners = [
  { name: 'sCrypt', logo: '/partners/scrypt.png' },
  { name: 'OP_CAT Labs', logo: '/partners/opcat-layer.jpg' },
  { name: 'Ark Labs', logo: '/partners/ark-labs.png' },
  { name: 'ParyonUSD', logo: '/partners/paryonusd.svg' },
];

const contactReasons = [
  'You are designing a UTXO smart contract protocol and need the transaction model reviewed.',
  'You need help turning a protocol spec into working scripts, transactions, tests, or wallet flows.',
  'You are preparing for launch and want an independent review before funds are at risk.',
  'You are unsure whether your covenant, state, or signing model is safe under adversarial conditions.',
];

const ecosystems = [
  'Bitcoin',
  'Bitcoin Cash',
  'OPCAT layer',
  'Liquid',
  'Arkade',
  'Fractal',
  'Bitcoin-like L2s',
];
---

<BaseLayout
  title="Sighash Labs | UTXO Programmability"
  description="UTXO smart contract development, consulting, and security audits for Bitcoin, Bitcoin Cash, OPCAT layer, Liquid, Arkade, Fractal, and Bitcoin-like L2s."
>
  <section class="relative isolate overflow-hidden">
    <div class="mx-auto flex max-w-6xl flex-col items-center px-6 pt-28 pb-20 text-center">
      <h1 class="mt-6 text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-6xl">
        UTXO programmability for
        <span class="text-rotator sm:ml-3" aria-live="polite">
          <span class="text-rotator-line">Bitcoin</span>
          <span class="text-rotator-line">Bitcoin Cash</span>
          <span class="text-rotator-line">Liquid</span>
          <span class="text-rotator-line">Arkade</span>
          <span class="text-rotator-line">Fractal</span>
        </span>
      </h1>
      <p class="mt-12 max-w-3xl text-lg text-slate-300 sm:mt-6">
        Sighash Labs helps teams design, build, and secure applications on Bitcoin, Bitcoin Cash, OPCAT layer, and Bitcoin-like UTXO systems. We provide consulting, development, and audits for smart contracts, covenant protocols, transaction flows, and L2 infrastructure.
      </p>
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a
          href="mailto:info@sighash.xyz"
          class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-8 py-3 text-base font-semibold text-white shadow-xl shadow-emerald-500/40 transition hover:-translate-y-0.5 hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
        >
          Discuss a UTXO project
        </a>
        <a
          href="/audits"
          class="inline-flex items-center justify-center rounded-full border border-white/10 px-8 py-3 text-base font-semibold text-white/80 transition hover:border-white/40 hover:text-white"
        >
          View audit archive
        </a>
      </div>
    </div>
  </section>

  {showPartners && (
    <section class="border-y border-white/5 bg-slate-950/60">
      <div class="mx-auto max-w-6xl px-6 py-10">
        <div class="flex flex-col gap-6 md:flex-row md:items-center">
          <div class="shrink-0 md:w-56">
            <p class="eyebrow">Worked with</p>
            <p class="mt-3 text-sm text-slate-300">Teams building UTXO smart contracts, Bitcoin L2s, and BCH DeFi.</p>
          </div>
          <div class="logo-marquee" aria-label="Companies Sighash Labs has worked with">
            <div class="logo-marquee-track" aria-hidden="true">
              {[...partners, ...partners].map((partner) => (
                <div class="logo-marquee-item">
                  <img src={partner.logo} alt="" loading="lazy" class="h-9 w-auto max-w-24 object-contain" />
                  <span>{partner.name}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="flex flex-col items-start gap-6 text-left md:flex-row md:items-center md:justify-between">
      <div>
        <p class="eyebrow">What we do</p>
        <h2 class="mt-3 text-3xl font-semibold text-white">Consulting, development, and audits for UTXO teams</h2>
        <p class="mt-4 max-w-2xl text-base text-slate-300">
          UTXO applications are won or lost in the details: script limits, transaction topology, state encoding, wallet behavior, mempool policy, and adversarial signing paths. We help teams reason through those constraints and ship working systems.
        </p>
      </div>
      <a href="mailto:info@sighash.xyz" class="text-sm font-semibold text-emerald-300 transition hover:text-white">
        Start a conversation
      </a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {services.map((service) => (
        <div class="glass-panel flex h-full flex-col gap-3 p-6">
          <h3 class="text-xl font-semibold text-white">{service.title}</h3>
          <p class="text-sm text-slate-300">{service.copy}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-slate-900/40">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="max-w-3xl">
        <p class="eyebrow">How we work</p>
        <h2 class="mt-3 text-3xl font-semibold text-white">From transaction design to launch review</h2>
        <p class="mt-4 text-base text-slate-300">
          Engagements can be advisory, implementation-heavy, audit-focused, or a mix. The common thread is precise reasoning about the UTXO model and the product constraints around it.
        </p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {processSteps.map((step, index) => (
          <div class="rounded-2xl border border-white/10 bg-slate-950/40 p-6 shadow-lg shadow-black/20">
            <span class="text-sm font-semibold text-emerald-300">0{index + 1}</span>
            <h3 class="mt-3 text-xl font-semibold text-white">{step.title}</h3>
            <p class="mt-3 text-sm text-slate-300">{step.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-900/40">
    <div class="mx-auto grid max-w-6xl gap-10 px-6 py-16 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div>
        <p class="eyebrow">When to contact us</p>
        <h2 class="mt-3 text-3xl font-semibold text-white">Bring us in before the transaction model hardens</h2>
        <p class="mt-4 text-base text-slate-300">
          The best time to catch UTXO protocol issues is while the architecture is still flexible. We can help at the design, build, or pre-launch review stage.
        </p>
        <a
          href="mailto:info@sighash.xyz"
          class="mt-8 inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-500/40 transition hover:-translate-y-0.5 hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
        >
          Discuss a UTXO project
        </a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {contactReasons.map((reason) => (
          <div class="rounded-2xl border border-white/10 bg-slate-950/40 p-5 shadow-lg shadow-black/20">
            <p class="text-sm leading-6 text-slate-200">{reason}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-10 lg:grid-cols-[2fr_1fr]">
      <div>
        <p class="eyebrow">Why sighash</p>
        <h2 class="mt-3 text-3xl font-semibold text-white">Specialized in Bitcoin-style programmability</h2>
        <p class="mt-4 text-base text-slate-300">
          General smart contract experience does not automatically translate to UTXO systems. Sighash Labs focuses on the transaction-level design, contract constraints, and protocol edge cases that matter on Bitcoin, Bitcoin Cash, and adjacent chains.
        </p>
        <ul class="mt-8 space-y-4">
          {valueProps.map((point) => (
            <li class="flex items-start gap-3 text-sm text-slate-200">
              <span class="mt-1 inline-flex h-2.5 w-2.5 rounded-full bg-emerald-400" aria-hidden="true"></span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
        <div class="mt-8 flex flex-wrap gap-3">
          {ecosystems.map((ecosystem) => (
            <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-slate-200">
              {ecosystem}
            </span>
          ))}
        </div>
      </div>
      <div class="glass-panel flex flex-col justify-between p-6">
        <div>
          <p class="text-sm font-semibold text-emerald-200">Separate audit archive</p>
          <h3 class="mt-3 text-2xl font-semibold text-white">Audits library</h3>
          <p class="mt-3 text-sm text-slate-300">
            Published audit reports remain available on a dedicated page, separate from consulting and development services.
          </p>
        </div>
        <a
          href="/audits"
          class="mt-8 inline-flex items-center justify-center rounded-full bg-white/10 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/20"
        >
          Explore past audits
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
